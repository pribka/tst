    "dev": "cross-env NODE_ENV=dev VUE_APP_BUILD_TYPE=dev vue-cli-service serve --host d.centersoft.kz --port 8080",
    "dev4gb": "cross-env NODE_ENV=dev VUE_APP_BUILD_TYPE=dev node --max-old-space-size=4096 node_modules/@vue/cli-service/bin/vue-cli-service.js serve --host d.centersoft.kz --port 8080",
    "build": "cross-env-shell NODE_ENV=production VUE_APP_BUILD_TYPE=production VUE_APP_BUILD_VERSION=$(date +%Y%m%d%H%M%S) \"node scripts/write-version.js && vue-cli-service build\"",
    "build-report": "cross-env-shell NODE_ENV=production VUE_APP_BUILD_TYPE=production VUE_APP_BUILD_VERSION=$(date +%Y%m%d%H%M%S) \"node scripts/write-version.js && vue-cli-service build --report\"",
